# AI 闹钟后端配置

# AI 语音服务 API Key
# ElevenLabs: https://elevenlabs.io
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# 或使用其他服务
# AZURE_SPEECH_KEY=your-azure-key
# AZURE_SPEECH_REGION=your-region

# 服务器配置
PORT=3000
HOST=localhost

# 文件上传限制 (MB)
MAX_FILE_SIZE=10

# 日志级别 (debug, info, warn, error)
LOG_LEVEL=info
