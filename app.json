{
  "expo": {
    "name": "AI 闹钟",
    "slug": "ai-alarm-clock",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./src/assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#6C63FF"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ai.alarmclock",
      "buildNumber": "1",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "需要访问麦克风以录制声音样本用于 AI 克隆",
        "NSAppleMusicUsageDescription": "需要访问音乐库以选择自定义铃声",
        "UIBackgroundModes": [
          "audio",
          "fetch"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/adaptive-icon.png",
        "backgroundColor": "#6C63FF"
      },
      "package": "com.ai.alarmclock",
      "versionCode": 1,
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "WAKE_LOCK",
        "FOREGROUND_SERVICE",
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./src/assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-av",
      "expo-notifications",
      "expo-document-picker"
    ],
    "extra": {
      "backendUrl": "http://localhost:3000"
    }
  }
}
